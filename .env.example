# ─── Django Core ─────────────────────────────────────────
# Generate a secret key for production: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=dummy_production_key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO

# ─── Database ────────────────────────────────────────────
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://good:password@localhost:5432/campusalert

# ─── Redis & Cache ───────────────────────────────────────
# Used for Django Cache, Sessions, and Celery
REDIS_URL=redis://127.0.0.1:6379/1

# ─── JWT Authentication ──────────────────────────────────
# Values in minutes (int) and days (int) as defined in settings.py
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed origins (e.g., your Flutter web or mobile)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Firebase / FCM ──────────────────────────────────────
FCM_PROJECT_ID=campusalert-firebase-id
FCM_SERVICE_ACCOUNT_JSON_PATH=/path/to/your/firebase-service-account.json

# ─── Project Specifics ───────────────────────────────────
COVENANT_EMAIL_DOMAIN=covenantuniversity.edu.ng

