###############################################################################
# .gitignore - Professional Git Ignore Configuration
# Project: Onehux Digital Services (ODS)
###############################################################################

###############################################################################
# IMPORTANT SYNTAX NOTES:
# /folder_name/*  - Targets folder_name directory at the ROOT level only
# folder_name/*   - Targets any folder_name directory ANYWHERE in the project
###############################################################################


###############################################################################
# PYTHON
###############################################################################
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
*.manifest
*.spec
MANIFEST

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# PEP 582
__pypackages__/


###############################################################################
# VIRTUAL ENVIRONMENTS
###############################################################################
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/


###############################################################################
# ENVIRONMENT VARIABLES
###############################################################################
.env
.env.local
.env.development
.env.dev
.env.production
.env.prod
.env.staging

# Keep the template safe to commit
# !.env.example


###############################################################################
# DJANGO
###############################################################################
*.log
*.pot
*.pyc
local_settings.py
db.sqlite3
db.sqlite3-journal


###############################################################################
# DATABASE FILES
###############################################################################
*.db
*.sqlite3
*.dump
*.sql


###############################################################################
# STATIC & MEDIA FILES (Root Level Only)
###############################################################################
/media/
/static/
/staticfiles/


###############################################################################
# GEOLOCATION DATABASES
###############################################################################
geoip/
geoip2/
GeoLite2-*.mmdb


